# PostgreSQL
DATABASE_URL=postgresql://travellta:travellta@localhost:5433/travellta

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Travelpayouts
TRAVELPAYOUTS_TOKEN=your_travelpayouts_token
TRAVELPAYOUTS_MARKER=your_partner_marker
TRAVELPAYOUTS_TRS=your_project_id

# AITUNNEL (OpenAI-совместимый доступ к LLM, модель DeepSeek)
AITUNNEL_API_KEY=your_aitunnel_api_key
AITUNNEL_BASE_URL=https://api.aitunnel.ru/v1/
AITUNNEL_MODEL=deepseek-v4-flash

# App URLs
# Локально:
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Продакшен:
# NEXT_PUBLIC_API_URL=https://travellta.apsago.com
# NEXT_PUBLIC_APP_URL=https://travellta.apsago.com
# CORS_ORIGIN=https://travellta.apsago.com

# Backend
PORT=3001
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# Auth (email/password + JWT)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d
# При старте API создаёт/обновляет админа с этими данными:
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password
